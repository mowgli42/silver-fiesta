# NFS Server Configuration
NFS_SERVER=nfs-server
NFS_SERVER_TYPE=kernel
NFS_VERSION=4
NFS_MOUNT_POINT=/mnt/nfs
NFS_MOUNT_OPTS=vers=4,proto=tcp

# Test Configuration
PYTEST_ARGS=-v
TEST_TIMEOUT=300
PERF_TESTS=0

# v2 Observability (SignOz-compatible OTLP)
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
# SIGNOZ_OTLP_ENDPOINT=https://ingest.<region>.signoz.cloud:443

# v2 Fault / diagnosis
FAULT_PROFILE=none
EXPECTED_FAILURES=0
